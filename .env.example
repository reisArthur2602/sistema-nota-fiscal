# URL pública da aplicação (usada em metadata, sitemap e OG tags)
NEXT_PUBLIC_URL="https://seudominio.com.br"

# Diretório onde os PDFs dos exames são salvos (pode ser um volume FTP montado)
UPLOAD_DIR="/var/www/exames"
