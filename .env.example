
DATABASE_URL="postgresql://user:password@localhost:5432/notafacil"

# Chave secreta para assinar os tokens JWT (use uma string longa e aleatória em produção)
JWT_SECRET="troque-por-uma-chave-secreta-forte-em-producao"

# Credenciais do usuário admin criado pelo seed
SEED_ADMIN_EMAIL="admin"
