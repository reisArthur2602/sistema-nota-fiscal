generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    SUPER_ADMIN
    LAUDO
}

model Usuario {
    id           String   @id @default(cuid())
    nome         String
    usuario      String   @unique
    senhaHash    String
    role         Role
    ativo        Boolean  @default(true)
    criadoEm     DateTime @default(now())
    atualizadoEm DateTime @updatedAt

    exames Exame[]
    logs   Log[]
}

model Exame {
    id             String   @id @default(cuid())
    cpf            String
    nomePaciente   String
    telefone       String?
    protocolo      String   @unique
    caminhoArquivo String
    ativo          Boolean  @default(true)
    criadoPorId    String
    criadoPor      Usuario  @relation(fields: [criadoPorId], references: [id])
    criadoEm      DateTime @default(now())
    atualizadoEm  DateTime @updatedAt
}

model Log {
    id        String   @id @default(cuid())
    tipo      String
    detalhes  Json?
    usuarioId String?
    usuario   Usuario? @relation(fields: [usuarioId], references: [id])
    criadoEm DateTime @default(now())
}

model Configuracao {
    chave        String   @id
    valor        Json?
    atualizadoEm DateTime @updatedAt
}
